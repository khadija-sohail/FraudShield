# Local defaults for XAMPP/LAMP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=fraudshield
DB_AUTO_CREATE=true

# Railway usually provides these automatically when a MySQL service is attached:
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# You can also use one URL instead:
# DATABASE_URL=mysql://user:password@host:3306/database
# MYSQL_URL=mysql://user:password@host:3306/database
